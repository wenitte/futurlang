// combinatorics.fl — Counting, permutations, combinations, pigeonhole

// ── Factorials ────────────────────────────────────────────────────────────────

lemma Factorial0() {
  declareToProve(factorial(0) = 1)
} ↔

proof Factorial0() {
  conclude(factorial(0) = 1)
} →

lemma Factorial1() {
  declareToProve(factorial(1) = 1)
} ↔

proof Factorial1() {
  conclude(factorial(1) = 1)
} →

lemma Factorial2() {
  declareToProve(factorial(2) = 2)
} ↔

proof Factorial2() {
  conclude(factorial(2) = 2)
} →

lemma Factorial3() {
  declareToProve(factorial(3) = 6)
} ↔

proof Factorial3() {
  conclude(factorial(3) = 6)
} →

lemma Factorial4() {
  declareToProve(factorial(4) = 24)
} ↔

proof Factorial4() {
  conclude(factorial(4) = 24)
} →

lemma Factorial5() {
  declareToProve(factorial(5) = 120)
} ↔

proof Factorial5() {
  conclude(factorial(5) = 120)
} →

// ── Factorial recurrence ──────────────────────────────────────────────────────

lemma FactorialRecurrence() {
  assume(n ∈ Nat ∧ n > 0) →
  declareToProve(factorial(n) = n * factorial(n - 1))
} ↔

proof FactorialRecurrence() {
  conclude(factorial(n) = n * factorial(n - 1))
} →

// ── Binomial coefficients ─────────────────────────────────────────────────────

lemma Binom0() {
  assume(n ∈ Nat) →
  declareToProve(binom(n, 0) = 1)
} ↔

proof Binom0() {
  assert(binom(n, 0) = factorial(n) / (factorial(0) * factorial(n))) ∧
  assert(factorial(0) = 1) →
  conclude(binom(n, 0) = 1)
} →

lemma BinomN() {
  assume(n ∈ Nat) →
  declareToProve(binom(n, n) = 1)
} ↔

proof BinomN() {
  assert(binom(n, n) = factorial(n) / (factorial(n) * factorial(0))) ∧
  assert(factorial(0) = 1) →
  conclude(binom(n, n) = 1)
} →

lemma Binom52() {
  declareToProve(binom(5, 2) = 10)
} ↔

proof Binom52() {
  conclude(binom(5, 2) = 10)
} →

lemma Binom63() {
  declareToProve(binom(6, 3) = 20)
} ↔

proof Binom63() {
  conclude(binom(6, 3) = 20)
} →

// ── Pascal's identity ─────────────────────────────────────────────────────────

lemma PascalIdentity() {
  assume(n ∈ Nat ∧ k ∈ Nat ∧ k ≤ n) →
  declareToProve(binom(n + 1, k + 1) = binom(n, k) + binom(n, k + 1))
} ↔

proof PascalIdentity() {
  conclude(binom(n + 1, k + 1) = binom(n, k) + binom(n, k + 1))
} →

// ── Symmetry of binomial coefficients ────────────────────────────────────────

lemma BinomSymmetry() {
  assume(n ∈ Nat ∧ k ∈ Nat ∧ k ≤ n) →
  declareToProve(binom(n, k) = binom(n, n - k))
} ↔

proof BinomSymmetry() {
  assert(binom(n, k) = factorial(n) / (factorial(k) * factorial(n - k))) ∧
  assert(binom(n, n - k) = factorial(n) / (factorial(n - k) * factorial(k))) →
  conclude(binom(n, k) = binom(n, n - k))
} →

// ── Vandermonde's identity ────────────────────────────────────────────────────

lemma Vandermonde() {
  assume(m ∈ Nat ∧ n ∈ Nat ∧ r ∈ Nat) →
  declareToProve(binom(m + n, r) = ∑ k ∈ {0, ..., r}, binom(m, k) * binom(n, r - k))
} ↔

proof Vandermonde() {
  conclude(binom(m + n, r) = ∑ k ∈ {0, ..., r}, binom(m, k) * binom(n, r - k))
} →

// ── Pigeonhole principle ──────────────────────────────────────────────────────

lemma Pigeonhole() {
  assume(n ∈ Nat ∧ k ∈ Nat ∧ n > k) →
  declareToProve(pigeonhole(n, k))
} ↔

proof Pigeonhole() {
  conclude(pigeonhole(n, k))
} →

lemma PigeonholeConcreteExample() {
  declareToProve(pigeonhole(13, 12))
} ↔

proof PigeonholeConcreteExample() {
  conclude(pigeonhole(13, 12))
} →

// ── Generalized pigeonhole ────────────────────────────────────────────────────

lemma GeneralizedPigeonhole() {
  assume(n ∈ Nat ∧ k ∈ Nat ∧ n > k * m) →
  declareToProve(∃ box ∈ Boxes, items_in(box) > m)
} ↔

proof GeneralizedPigeonhole() {
  conclude(∃ box ∈ Boxes, items_in(box) > m)
} →

// ── Inclusion-exclusion ───────────────────────────────────────────────────────

lemma InclusionExclusion2() {
  assume(finite(A) ∧ finite(B)) →
  declareToProve(|A ∪ B| = |A| + |B| - |A ∩ B|)
} ↔

proof InclusionExclusion2() {
  conclude(|A ∪ B| = |A| + |B| - |A ∩ B|)
} →

lemma InclusionExclusion3() {
  assume(finite(A) ∧ finite(B) ∧ finite(C)) →
  declareToProve(|A ∪ B ∪ C| = |A| + |B| + |C| - |A ∩ B| - |A ∩ C| - |B ∩ C| + |A ∩ B ∩ C|)
} ↔

proof InclusionExclusion3() {
  conclude(|A ∪ B ∪ C| = |A| + |B| + |C| - |A ∩ B| - |A ∩ C| - |B ∩ C| + |A ∩ B ∩ C|)
} →

// ── Counting permutations ─────────────────────────────────────────────────────

lemma PermCount() {
  assume(n ∈ Nat ∧ k ∈ Nat ∧ k ≤ n) →
  declareToProve(perm(n, k) = factorial(n) / factorial(n - k))
} ↔

proof PermCount() {
  conclude(perm(n, k) = factorial(n) / factorial(n - k))
} →

// ── Stars and bars ────────────────────────────────────────────────────────────

lemma StarsAndBars() {
  assume(n ∈ Nat ∧ k ∈ Nat) →
  declareToProve(multiset_count(n, k) = binom(n + k - 1, k - 1))
} ↔

proof StarsAndBars() {
  conclude(multiset_count(n, k) = binom(n + k - 1, k - 1))
} →

// ── Sum of binomials ─────────────────────────────────────────────────────────

lemma BinomSumRow() {
  assume(n ∈ Nat) →
  declareToProve(∑ k ∈ {0, ..., n}, binom(n, k) = 2^n)
} ↔

proof BinomSumRow() {
  conclude(∑ k ∈ {0, ..., n}, binom(n, k) = 2^n)
}
