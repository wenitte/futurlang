// ── Even / odd ────────────────────────────────────────────────────────────────

lemma EvenDouble() {
  given(n ∈ Nat) →
  assert(even(2 * n))
} ↔

proof EvenDouble() {
  given(n ∈ Nat) →
  assert(even(2 * n))
} →

lemma EvenPlusEven() {
  given(a ∈ Nat) →
  given(b ∈ Nat) →
  given(even(a)) →
  given(even(b)) →
  assert(even(a + b))
} ↔

proof EvenPlusEven() {
  given(a ∈ Nat) →
  given(b ∈ Nat) →
  given(even(a)) →
  given(even(b)) →
  assert(even(a + b))
} →

lemma EvenTimesAny() {
  given(a ∈ Nat) →
  given(b ∈ Nat) →
  given(even(a)) →
  assert(even(a * b))
} ↔

proof EvenTimesAny() {
  given(a ∈ Nat) →
  given(b ∈ Nat) →
  given(even(a)) →
  assert(even(a * b))
} →

lemma EvenSquareImpliesEven() {
  given(n ∈ Nat) →
  given(even(n * n)) →
  assert(even(n))
} ↔

proof EvenSquareImpliesEven() {
  given(n ∈ Nat) →
  given(even(n * n)) →
  assert(even(n))
} →

