// ── Number theory ─────────────────────────────────────────────────────────────

lemma Sqrt2Irrational() {
  given(p ∈ Nat) →
  given(q ∈ Nat) →
  given(k ∈ Nat) →
  given(p * p = 2 * (q * q)) →
  given(p = 2 * k) →
  given(coprime(p, q)) →
  assert(⊥)
} ↔

proof Sqrt2Irrational() {
  given(p ∈ Nat) →
  given(q ∈ Nat) →
  given(k ∈ Nat) →
  given(p * p = 2 * (q * q)) →
  given(p = 2 * k) →
  given(coprime(p, q)) →
  assert(even(p * p)) →
  assert(even(p)) →
  assert(p * p = 4 * (k * k)) →
  assert(2 * (q * q) = 4 * (k * k)) →
  assert(q * q = 2 * (k * k)) →
  assert(even(q * q)) →
  assert(even(q)) →
  assert(⊥)
} →

// ── Modular arithmetic ────────────────────────────────────────────────────────

lemma FermatLittle() {
  given(p ∈ Prime) →
  given(a ∈ Nat) →
  given(coprime(a, p)) →
  assert(a^(p - 1) ≡ 1 (mod p))
} ↔

proof FermatLittle() {
  given(p ∈ Prime) →
  given(a ∈ Nat) →
  given(coprime(a, p)) →
  assert(a^(p - 1) ≡ 1 (mod p))
} →

lemma EulerTheorem() {
  given(n ∈ Nat) →
  given(a ∈ Nat) →
  given(coprime(a, n)) →
  assert(a^φ(n) ≡ 1 (mod n))
} ↔

proof EulerTheorem() {
  given(n ∈ Nat) →
  given(a ∈ Nat) →
  given(coprime(a, n)) →
  assert(a^φ(n) ≡ 1 (mod n))
} →

lemma RSACorrectness() {
  given(n ∈ Nat) →
  given(e ∈ Nat) →
  given(d ∈ Nat) →
  given(m ∈ Nat) →
  given(e * d ≡ 1 (mod φ(n))) →
  assert((m^e)^d ≡ m (mod n))
} ↔

proof RSACorrectness() {
  given(n ∈ Nat) →
  given(e ∈ Nat) →
  given(d ∈ Nat) →
  given(m ∈ Nat) →
  given(e * d ≡ 1 (mod φ(n))) →
  assert((m^e)^d ≡ m (mod n))
}
