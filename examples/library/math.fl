// math.fl — FuturLang standard mathematics library
// Proved lemmas that can be imported with apply(LemmaName)

// ── Arithmetic identities ─────────────────────────────────────────────────────

lemma AddZero() {
  given(n ∈ Nat) →
  assert(n + 0 = n)
} ↔

proof AddZero() {
  given(n ∈ Nat) →
  assert(n + 0 = n)
} →

