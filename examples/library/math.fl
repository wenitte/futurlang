lemma NatNonNeg() {
  given(n ∈ Nat) →
  assert(n ≥ 0)
} ↔

proof NatNonNeg() {
  given(n ∈ Nat) →
  assert(n ≥ 0)
} →

lemma SquareNonNeg() {
  given(n ∈ Int) →
  assert(n * n ≥ 0)
} ↔

proof SquareNonNeg() {
  given(n ∈ Int) →
  assert(n * n ≥ 0)
} →

lemma AbsNonNeg() {
  given(n ∈ Int) →
