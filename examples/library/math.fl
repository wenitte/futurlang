lemma MulAssoc() {
  given(a ∈ Nat) →
  given(b ∈ Nat) →
  given(c ∈ Nat) →
  assert(a * (b * c) = a * b * c)
} ↔

proof MulAssoc() {
  given(a ∈ Nat) →
