theorem IntersectionMembershipIff() {
  assert((x ∈ A ∩ B) ↔ (x ∈ A ∧ x ∈ B))
} ↔

proof IntersectionMembershipIff() {
  assume(x ∈ A ∩ B) →
  assert(x ∈ A) ∧
  assert(x ∈ B) →
  assert(x ∈ A ∧ x ∈ B) →
  assert((x ∈ A ∩ B) → (x ∈ A ∧ x ∈ B)) →
  assume(x ∈ A ∧ x ∈ B) →
  assert(x ∈ A) →
  assert(x ∈ B) →
  assert(x ∈ A ∩ B) →
  assert((x ∈ A ∧ x ∈ B) → (x ∈ A ∩ B)) →
  conclude((x ∈ A ∩ B) ↔ (x ∈ A ∧ x ∈ B))
}
