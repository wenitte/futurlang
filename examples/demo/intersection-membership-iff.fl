theorem IntersectionMembershipIff() {
  declareToProve((x ∈ A ∩ B) ↔ (x ∈ A ∧ x ∈ B))
} ↔

proof IntersectionMembershipIff() {
  assume(x ∈ A ∩ B) →
  prove(x ∈ A) ∧
  prove(x ∈ B) →
  prove(x ∈ A ∧ x ∈ B) →
  prove((x ∈ A ∩ B) → (x ∈ A ∧ x ∈ B)) →
  assume(x ∈ A ∧ x ∈ B) →
  prove(x ∈ A) →
  prove(x ∈ B) →
  prove(x ∈ A ∩ B) →
  prove((x ∈ A ∧ x ∈ B) → (x ∈ A ∩ B)) →
  conclude((x ∈ A ∩ B) ↔ (x ∈ A ∧ x ∈ B))
}
