// lagrange.fl

// Universe levels for type definitions
level u → 

// Type definitions
struct Group@{u} {
  carrier: Set@{u};
  operation: carrier → carrier → carrier;
  identity: carrier;
  inverse: carrier → carrier
} →

struct Subgroup@{u} {
  parent: Group@{u};
  elements: Set@{u}
} →

// Main theorem definition
theorem Lagrange_Theorem() {
  assert(
    ∀(G: Group) ⇒
      ∀(H: Subgroup(G)) ⇒
        (
          |G| = |H| · [G:H] →
          |H| divides |G|
        )
  )
} ↔ // Equivalent to its proof

proof Lagrange_Theorem() {
  setVar(G: Group) →
  setVar(H: Subgroup(G)) →
  assume(|G| = |H| · [G:H]) →
  conclude(|H| divides |G|)
}
